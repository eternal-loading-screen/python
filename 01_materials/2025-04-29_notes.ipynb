# %% [markdown]
# # Writing custom / your own functions
# 
# Starts with def_
# Case sensitive and cannot start with numbers
# parameters > only used in a function
# 
# >> make sure to indent
# function_name(arguments):
#     "docstring"
#     body
#     return statement
# 
# Without a return statement, it will be implicit; and return none

# %%
# Celcsius converter function

# note the use of the parameter
def c_to_f(degrees_c):
    # not the indent
    degrees_f = (9/5) * degrees_c +32
    # if this was not present, then it would return none
    return degrees_f

# %%
c_to_f(100)

# %%
c_to_f(-10)

# %%
# save output of function
freezing_f = c_to_f(0)

# %%
freezing_f

